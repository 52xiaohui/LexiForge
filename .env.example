# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# All variables consumed by backend/internal/config/config.go.

# --- Application -------------------------------------------------------------
APP_ENV=development
APP_PORT=8080
LOG_LEVEL=info

# Comma-separated browser origins allowed to call the API.
# Example: https://lexiforge.vercel.app,https://www.lexiforge.app
# Use * to allow any browser origin.
CORS_ALLOWED_ORIGINS=

# Required in production. Generate with: openssl rand -hex 32
# The browser asks for this value and keeps it in sessionStorage.
APP_ACCESS_TOKEN=

# Process-local cost guards for paid/external operations.
AI_RATE_LIMIT_PER_MINUTE=5
SYNC_RATE_LIMIT_PER_MINUTE=2

# --- Database ----------------------------------------------------------------
# Local dev (running `go run ./cmd/server` directly):
DATABASE_URL=postgres://lexiforge:lexiforge@localhost:5432/lexiforge?sslmode=disable

# --- MaiMemo Open API (MVP single-user) --------------------------------------
MAIMEMO_TOKEN=

# --- AI provider (OpenAI-compatible) ----------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
