# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# All variables consumed by backend/internal/config/config.go.

# --- Application -------------------------------------------------------------
APP_ENV=development
APP_PORT=8080
LOG_LEVEL=info

# --- Database ----------------------------------------------------------------
# Local dev (running `go run ./cmd/server` directly):
DATABASE_URL=postgres://lexiforge:lexiforge@localhost:5432/lexiforge?sslmode=disable
# Docker compose overrides this to the in-network host `postgres` automatically.

# --- MaiMemo Open API (MVP single-user, see docs/07-security.md) ------------
MAIMEMO_TOKEN=

# --- AI provider (OpenAI-compatible) ----------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
